   <content>
      <faultIsolation>
         <faultIsolationProcedure>
            <fault faultCode="F0321" />
            <faultDescr>
               <descr>故障现象的描述</descr>
            </faultDescr>
            <isolationProcedure>
               <isolationMainProcedure>
                  <isolationStep id="stp-0001">
                     <action>启动发动机，保持怠速运转。</action>
                     <isolationStepQuestion>是否听到异常响声？</isolationStepQuestion>
                     <isolationStepAnswer>
                        <yesNoAnswer>
                           <yesAnswer nextActionRefId="stp-0002" />
                           <noAnswer nextActionRefId="sto-0004" />
                        </yesNoAnswer>
                     </isolationStepAnswer>
                  </isolationStep>
                  <isolationStep id="stp-0002">
                     <action>逐步提高发动机转速至2000rpm</action>
                     <isolationStepQuestion>响声是否随转速增加而变大？</isolationStepQuestion>
                     <isolationStepAnswer>
                        <yesNoAnswer>
                           <yesAnswer nextActionRefId="stp-0003" />
                           <noAnswer nextActionRefId="stp-0004" />
                        </yesNoAnswer>
                     </isolationStepAnswer>
                  </isolationStep>
                  <isolationStep id="stp-0003">
                     <action>逐步提高发动机转速至3000rpm，使用设备测量噪音频率。</action>
                     <isolationStepQuestion>噪音范围为?</isolationStepQuestion>
                     <isolationStepAnswer>
                        <listOfChoices>
                           <choice nextActionRefId="stp-0003"></choice>
                           <choice nextActionRefId="stp-0003"></choice>
                           <choice nextActionRefId="stp-0003"></choice>
                        </listOfChoices>
                     </isolationStepAnswer>
                  </isolationStep>
                  <isolationProcedureEnd id="stp-0004">
                     <title>故障定位完成</title>
                     <action>故障定位完成，建议更换气门间隙调节器。记录故障现象和处理过程，更新维修记录。</action>
                  </isolationProcedureEnd>
               </isolationMainProcedure>
            </isolationProcedure>
         </faultIsolationProcedure>
