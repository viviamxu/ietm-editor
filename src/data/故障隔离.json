{
  "dmodule": {
    "cnName": "数据模块",
    "content": "rdfDescription? identAndStatusSection content"
  },
  "rdfDescription": {
    "content": "(dctitle|dccreator|dcsubject|dcpublisher|dccontributor|dcsource|dcdate)? dctype (dcformat| dcidentifier|dclanguage|dcrights)?"
  },
  "dctitle": {
    "content": "text*"
  },
  "dccreator": {
    "content": "text*"
  },
  "dcsubject": {
    "content": "text*"
  },
  "dcpublisher": {
    "content": "text*"
  },
  "dccontributor": {
    "content": "text*"
  },
  "dcsource": {
    "content": "text*"
  },
  "dcdate": {
    "content": "text*"
  },
  "dctype": {
    "content": "text*"
  },
  "dcformat": {
    "content": "text*"
  },
  "dcidentifier": {
    "content": "text*"
  },
  "dclanguage": {
    "content": "text*"
  },
  "dcrights": {
    "content": "text*"
  },
  "title": {
    "content": "(text)*"
  },
  "identAndStatusSection": {
    "content": "dmAddress dmStatus"
  },
  "dmAddress": {
    "content": "dmIdent dmAddressItems"
  },
  "dmIdent": {
    "content": "dmCode language issueInfo"
  },
  "identExtension": {
    "content": "text*"
  },
  "dmCode": {},
  "language": {
    "content": ""
  },
  "issueInfo": {
    "content": ""
  },
  "dmAddressItems": {
    "content": "issueDate dmTitle"
  },
  "issueDate": {},
  "dmTitle": {
    "content": "techName infoName"
  },
  "techName": {
    "content": "text*"
  },
  "infoName": {
    "content": "text*"
  },
  "dmStatus": {
    "content": "security responsiblePartnerCompany originator applic brexDmRef qualityAssurance"
  },
  "security": {
    "content": ""
  },
  "responsiblePartnerCompany": {
    "content": "enterpriseName"
  },
  "originator": {
    "content": "enterpriseName"
  },
  "enterpriseName": {
    "content": "text*"
  },
  "applic": {
    "content": "displayText"
  },
  "brexDmRef": {
    "content": "dmRef"
  },
  "displayText": {
    "content": "simplePara*"
  },
  "qualityAssurance": {
    "content": "unverified|(firstVerification secondVerification?)"
  },
  "dmRef": {
    "group": "textElemGroup",
    "content": "dmRefIdent dmRefAddressItems"
  },
  "dmRefIdent": {
    "content": "dmCode issueInfo language"
  },
  "dmRefAddressItems": {
    "content": "dmTitle issueDate"
  },
  "preliminaryRqmts": {
    "content": "reqCondGroup reqPersons reqSupportEquips reqSupplies reqSpares reqSafety"
  },
  "reqCondGroup": {
    "content": "noConds|reqCondNoRef+"
  },
  "reqCondNoRef": {
    "content": "reqCond"
  },
  "reqCond": {
    "content": "text*"
  },
  "noConds": {
    "content": "text*"
  },
  "reqPersons": {
    "content": "personnel*"
  },
  "personnel": {
    "content": "personCategory personSkill trade estimatedTime"
  },
  "personCategory": {
    "content": "text*"
  },
  "personSkill": {
    "content": "text*"
  },
  "trade": {
    "content": "text*"
  },
  "estimatedTime": {
    "content": "text*"
  },
  "reqSupportEquips": {
    "content": "noSupportEquips | supportEquipDescrGroup"
  },
  "noSupportEquips": {
    "content": "text*"
  },
  "supportEquipDescrGroup": {
    "content": "supportEquipDescr+"
  },
  "supportEquipDescr": {
    "content": "name natoStockNumber identNumber reqQuantity remarks"
  },
  "reqSupplies": {
    "content": "noSupplies | supplyDescrGroup"
  },
  "noSupplies": {
    "content": "text*"
  },
  "supplyDescrGroup": {
    "content": "supplyDescr+"
  },
  "supplyDescr": {
    "content": "name natoStockNumber identNumber reqQuantity remarks"
  },
  "reqSpares": {
    "content": "noSpares|spareDescrGroup"
  },
  "spareDescrGroup": {
    "content": "spareDescr+"
  },
  "spareDescr": {
    "content": "name natoStockNumber identNumber reqQuantity remarks"
  },
  "identNumber": {
    "content": "partAndSerialNumber"
  },
  "partAndSerialNumber": {
    "content": "partNumber"
  },
  "partNumber": {
    "content": "text*"
  },
  "name": {
    "content": "text*"
  },
  "reqQuantity": {
    "content": "text*"
  },
  "natoStockNumber": {
    "content": "text*"
  },
  "remarks": {
    "content": "text*"
  },
  "noSpares": {
    "content": "text*"
  },
  "reqSafety": {
    "content": "noSafety|safetyRqmts"
  },
  "safetyRqmts": {
    "content": "attentionElemGroup+"
  },
  "warning": {
    "group": "attentionElemGroup warningAndCautionElemGroup",
    "content": "warningAndCautionPara+"
  },
  "caution": {
    "group": "attentionElemGroup warningAndCautionElemGroup",
    "content": "warningAndCautionPara+"
  },
  "warningAndCautionPara": {
    "content": "text*"
  },
  "note": {
    "group": "attentionElemGroup",
    "content": "notePara+"
  },
  "notePara": {
    "content": "text*"
  },
  "attentionRandomList": {
    "content": "attentionRandomListItem+"
  },
  "attentionRandomListItem": {
    "content": "attentionListItemPara+"
  },
  "attentionListItemPara": {
    "content": "(text|attentionTextGroup)*"
  },
  "internalRef": {
    "group": "textElemGroup attentionTextGroup",
    "content": "text*"
  },
  "emphasis": {
    "group": "textElemGroup attentionTextGroup"
  },
  "subScript": {
    "group": "textElemGroup attentionTextGroup"
  },
  "superScript": {
    "group": "textElemGroup attentionTextGroup"
  },
  "symbol": {
    "group": "textElemGroup attentionTextGroup"
  },
  "closeRqmts": {
    "content": "reqCondGroup"
  },
  "content": {
    "content": "faultIsolation"
  },
  "faultIsolation": {
    "content": "preliminaryRqmts? faultIsolationProcedure+"
  },
  "faultIsolationProcedure": {
    "content": "fault faultDescr isolationProcedure "
  },
  "faultDescr": {
    "content": "descr"
  },
  "descr": {
    "content": "text*"
  },
  "isolationProcedure": {
    "content": "preliminaryRqmts isolationMainProcedure closeRqmts"
  },
  "isolationMainProcedure": {
    "content": "(isolationStep|isolationProcedureEnd)+"
  },
  "isolationProcedureEnd": {
    "content": "title action"
  },
  "isolationStep": {
    "content": "title action isolationStepQuestion isolationStepAnswer"
  },
  "action": {
    "content": "(text)*"
  },
  "isolationStepQuestion": {
    "content": "(text)*"
  },
  "isolationStepAnswer": {
    "content": "yesNoAnswer | listOfChoices"
  },
  "yesNoAnswer": {
    "content": "yesAnswer noAnswer"
  },
  "listOfChoices": {
    "content": "choice+"
  },
  "choice": {
    "content": "text*"
  }
}