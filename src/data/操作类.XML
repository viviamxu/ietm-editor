<?xml version="1.0" encoding="utf-8"?><!DOCTYPE dmodule >
<dmodule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:dc="http://www.purl.org/dc/elements/1.1/"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xlink="http://www.w3.org/1999/xlink"
         xsi:noNamespaceSchemaLocation="http://www.s1000d.org/S1000D_4-2/xml_schema_flat/crew.xsd">

   <content>
   <crew>
         <crewRefCard>
            <title>操作卡片标题</title>
            <warning>
               <warningAndCautionPara>省略...</warningAndCautionPara>
            </warning>
            <para>这里允许插入段落文本</para>
            <para>省略</para>
            <crewDrill>
               <title>操作标题</title>
               <warning>
                  <warningAndCautionPara>省略...</warningAndCautionPara>
               </warning>
                 <table>
                  <title/>   
                  <tgroup cols="1">
                    <tbody>
                      <row>
                        <entry>
                          <para>
                            最小
                          </para>
                        </entry>
                      </row>
                    </tbody>
                  </tgroup>
                </table>
               <crewDrillStep>
                  <title>操作步骤标题第一步</title>
                  <para>使用备份验证工具检查最近一次的备份文件是否完整，确保没有损坏或缺失的数据块。</para>
                  <crewDrillStep>
                     <title>操作子步骤标题</title>
                     <challengeAndResponse>
                        <challenge><para>确认控制台可以正常访问，显示所有备份任务列表</para></challenge>
                        <response><para>确认控制台可以正常访问，显示所有备份任务列表</para></response>
                     </challengeAndResponse>
                     <challengeAndResponse>
                        <challenge><para>确认控制台可以正常访问，显示所有备份任务列表</para></challenge>
                        <response><para>确认控制台可以正常访问，显示所有备份任务列表</para></response>
                     </challengeAndResponse>
                  </crewDrillStep>
                  <crewDrillStep>
                     <title>操作子步骤标题</title>
                     <figure>
                        <title>图片标题</title>
                        <!-- <graphic infoEntityIdent="XXX"></graphic> -->
                     </figure>
                  </crewDrillStep>
               </crewDrillStep>
               <crewDrillStep>
                  <title>操作标题第二步</title>
                  <table>
                     <title/>   
                     <tgroup cols="1">
                     <tbody>
                        <row>
                           <entry>
                           <para>
                              第2个
                           </para>
                           </entry>
                        </row>
                     </tbody>
                     </tgroup>
                  </table>
                  <!-- <if>
                     <caseCond>如果的条件输入:当系统压力低于 0.5MPa 时</caseCond>
                     <crewDrillStep><title>如果的操作子步骤标题1</title><para>如果的操作子步骤内容</para></crewDrillStep>
                     <crewDrillStep><title>如果的操作子步骤标题2</title></crewDrillStep>
                  </if> -->
                  <if id="if-demo">
                     <!-- 必须的开头：判断条件 -->
                     <caseCond>系统模式切换至应急状态</caseCond>
                   
                     <!-- 主体1：普通执行步骤 -->
                     <crewDrillStep><title>关闭主供电回路</title><para>关闭主供电回路内容</para></crewDrillStep>
                   
                     <!-- 主体2：case多分支项 -->
                     <case>
                       <caseCond>应急电源电量>80%</caseCond>
                       <crewDrillStep><title>启动一级应急保障</title></crewDrillStep>
                     </case>
                     <case>
                        <caseCond>应急电源电量>60%</caseCond>
                        <crewDrillStep><title>启动二级应急保障</title></crewDrillStep>
                      </case>
                     <!-- 主体3：嵌套if+elseIf分支 -->
                     <if>
                       <caseCond>现场有操作人员值守</caseCond>
                       <crewDrillStep><title>手动确认设备状态</title></crewDrillStep>
                     </if>
                     <elseIf>
                       <caseCond>现场无人值守</caseCond>
                       <crewDrillStep><title>触发远程告警</title></crewDrillStep>
                     </elseIf>
                   
                     <!-- 主体4：又一个普通执行步骤（重复出现同类型） -->
                     <crewDrillStep><title>记录故障日志并上报</title></crewDrillStep>
                   </if>
                  <elseIf>
                     <caseCond>否则如果的条件输入</caseCond>
                     <crewDrillStep><title>否则如果的操作子步骤标题1</title></crewDrillStep>
                     <crewDrillStep><title>否则如果的操作子步骤标题2</title></crewDrillStep>
                  </elseIf>
               </crewDrillStep>
               <crewDrillStep>
                  <warning>
                     <warningAndCautionPara>省略...</warningAndCautionPara>
                  </warning>
                  <table>
