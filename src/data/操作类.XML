                     <tgroup cols="1">
                     <tbody>
                        <row>
                           <entry>
                           <para>
                              最小
                           </para>
                           </entry>
                        </row>
                     </tbody>
                     </tgroup>
                  </table>
                  <case>
                     <caseCond>如果的条件输入</caseCond>
                     <crewDrillStep><title>省略...</title></crewDrillStep>
                     <crewDrillStep><title>省略...</title></crewDrillStep>
                  </case>
                  <case>
                     <caseCond>如果的条件输入</caseCond>
                     <crewDrillStep><title>省略...</title></crewDrillStep>
                     <crewDrillStep><title>末尾</title><para>sdfds</para></crewDrillStep>
                  </case>
               </crewDrillStep>
            </crewDrill>
            
