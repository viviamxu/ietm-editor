{
  "name": "@ccengine/ietm-editor",
  "version": "1.6.5",
  "type": "module",
  "description": "S1000D IETM editor SDK (React island, Vanilla shell). Framework-agnostic mount API for Vue / React / vanilla hosts.",
  "license": "UNLICENSED",
  "author": "ccengine",
  "keywords": [
    "s1000d",
    "ietm",
    "tiptap",
    "editor",
    "react",
    "vue"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./style.dark.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://nexus.ccengine.com/repository/cc-npm/",
    "access": "restricted"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build -c vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build:demo": "tsc -b && vite build --outDir dist-demo",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "pnpm build",
    "release:patch": "pnpm version patch && pnpm publish",
    "release:minor": "pnpm version minor && pnpm publish",
    "release:major": "pnpm version major && pnpm publish"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "@dagrejs/dagre": "^3.0.0",
    "@ietm-manual/preview": "^0.0.3",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-highlight": "3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-list-item": "3.22.5",
    "@tiptap/extension-text-align": "3.22.5",
    "@tiptap/extension-text-style": "3.22.5",
    "@tiptap/extension-underline": "3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-syntax-highlighter": "16.1.1",
    "reactflow": "^11.11.4",
    "xml-formatter": "^3.7.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@arco-plugins/vite-react": "^1.3.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "less": "^4.6.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
